# Exemplo de Configuração de Ambiente - PRODUCTION
# Copie este arquivo para .env e configure os valores reais

# === CORE ===
FLASK_ENV=production
# Em desenvolvimento, defina como: development

# === DATABASE (MySQL — único motor suportado) ===
# Produção (Azure):     mysql+pymysql://usuario:senha@host:3306/estoque_db
# Dev/teste (container): mysql+pymysql://estoque:estoque123@127.0.0.1:3306/estoque_db
DATABASE_URL=mysql+pymysql://usuario:senha@localhost:3306/estoque_db

# === SEGURANÇA (OBRIGATÓRIO EM PRODUÇÃO) ===
# Gere uma SECRET_KEY com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=NUNCA-USE-ESTE-VALOR-GERE-UM-NOVO-COM-secrets-token_hex

# === COOKIES DE SESSÃO ===
# Em produção com HTTPS, defina como True:
SESSION_COOKIE_SECURE=True
# Opções: Strict, Lax, None (padrão recomendado: Lax)
SESSION_COOKIE_SAMESITE=Lax

# === EMAIL (RECOMENDADO EM PRODUÇÃO) ===
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-senha-de-app
MAIL_DEFAULT_SENDER=noreply@estoque.com
# Emails dos administradores (separados por vírgula):
ADMIN_EMAILS=admin1@example.com,admin2@example.com

# === POWER AUTOMATE / TEAMS ===
# URL do webhook do canal no Teams (Incoming Webhook)
TEAMS_CHANNEL_WEBHOOK_URL=

# Compatibilidade com integrações antigas via Power Automate
# Cole aqui a URL do gatilho HTTP do fluxo do Power Automate
POWER_AUTOMATE_WEBHOOK_URL=
# Tempo máximo, em segundos, para aguardar a resposta do fluxo
POWER_AUTOMATE_TIMEOUT_SECONDS=10

# URL pública base da aplicação (opcional, para exibir imagens no Teams)
APP_PUBLIC_BASE_URL=

# === MICROSOFT ENTRA ID (Azure AD) - AUTENTICAÇÃO SSO ===
# Deixe em branco se não usar autenticação via Entra ID
# Obtenha essas informações no portal Azure (https://portal.azure.com)

# ID da aplicação registrada no Entra ID (Application ID / Client ID)
ENTRA_CLIENT_ID=

# Segredo da cliente gerado para a aplicação (Client Secret / Secret Value)
# MANTÉM SEGURO - NUNCA COMMIT PARA GIT
ENTRA_CLIENT_SECRET=

# ID do tenant da sua organização (Directory ID / Tenant ID)
ENTRA_TENANT_ID=

# URL de autoridade (preenchida automaticamente, mas pode ser customizada)
# Padrão: https://login.microsoftonline.com/{TENANT_ID}
# Para nuvens nacionais, use:
#   - Gov cloud: https://login.microsoftonline.us/{TENANT_ID}
#   - China: https://login.chinacloudapi.cn/{TENANT_ID}
ENTRA_AUTHORITY=

# Caminho relativo de callback após autenticação (padrão: /entra/callback)
# Certifique-se que essa URL está registrada como "Redirect URI" na aplicação Entra
ENTRA_REDIRECT_PATH=/entra/callback

