# Exemplo de Configuração de Ambiente - PRODUCTION
# Copie este arquivo para .env e configure os valores reais

# === CORE ===
FLASK_ENV=production
# Em desenvolvimento, defina como: development

# === DATABASE ===
# Exemplos de URLs de banco:
# SQLite: sqlite:///C:/caminho/absoluto/instance/estoque.sqlite
# MySQL:  mysql+pymysql://usuario:senha@localhost:3306/estoque_db

DATABASE_URL=mysql+pymysql://usuario:senha@localhost:3306/estoque_db

# === SEGURANÇA (OBRIGATÓRIO EM PRODUÇÃO) ===
# Gere uma SECRET_KEY com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=NUNCA-USE-ESTE-VALOR-GERE-UM-NOVO-COM-secrets-token_hex

# === COOKIES DE SESSÃO ===
# Em produção com HTTPS, defina como True:
SESSION_COOKIE_SECURE=True
# Opções: Strict, Lax, None (padrão recomendado: Lax)
SESSION_COOKIE_SAMESITE=Lax

# === EMAIL (RECOMENDADO EM PRODUÇÃO) ===
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-senha-de-app
MAIL_DEFAULT_SENDER=noreply@estoque.com
# Emails dos administradores (separados por vírgula):
ADMIN_EMAILS=admin1@example.com,admin2@example.com

