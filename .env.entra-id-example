# ============================================================================
# === MICROSOFT ENTRA ID (NOVO) ===
# ============================================================================
# Estes valores vêm do Azure Portal - App Registration

# ID da aplicação registrada (Application ID / Client ID)
# Encontrar em: Azure Portal > Entra ID > App registrations > [sua app] > Overview
ENTRA_CLIENT_ID=8a9c3e4f-2b6d-4f8e-a1c9-7d3e5f2a8b4c

# Segredo do cliente (Client Secret / Secret Value)
# ⚠️ SUPER SECRETO - Gere em: Certificates & Secrets > Client secrets
ENTRA_CLIENT_SECRET=W~.1a-bCdEfGhIjKlMnOpQrStUvWxYzAbCdEfGhI.KjL

# ID do tenant (Directory ID / Tenant ID)
# Encontrar em: Azure Portal > Entra ID > Overview
ENTRA_TENANT_ID=72f988bf-86f1-41af-91ab-2d7cd011db47

# URL de autoridade (auto-preenchida, mas pode customizar)
# Padrão: https://login.microsoftonline.com/{TENANT_ID}
ENTRA_AUTHORITY=https://login.microsoftonline.com/72f988bf-86f1-41af-91ab-2d7cd011db47

# Caminho relativo de callback (deve corresponder ao Redirect URI no Azure)
ENTRA_REDIRECT_PATH=/entra-callback

# ============================================================================
# INSTRUÇÕES PARA OBTER OS VALORES
# ============================================================================
#
# 1. ENTRA_CLIENT_ID e ENTRA_TENANT_ID:
#    - Vá para https://portal.azure.com
#    - Procure por "Entra ID" ou "Azure Active Directory"
#    - Clique em "App registrations"
#    - Clique em sua aplicação
#    - Na aba "Overview", copie:
#      * "Application (client) ID" → ENTRA_CLIENT_ID
#      * "Directory (tenant) ID" → ENTRA_TENANT_ID
#
# 2. ENTRA_CLIENT_SECRET:
#    - No mesmo Azure Portal, na sua app
#    - Vá para "Certificates & secrets"
#    - Clique "New client secret"
#    - Descrição: "ESTOQUE Flask App"
#    - Expirando: Escolha conforme sua política
#    - Clique "Add"
#    - ⚠️ COPIE IMEDIATAMENTE O "Value" (não mostra depois!)
#    - Cole em ENTRA_CLIENT_SECRET
#
# 3. Verificar Redirect URIs:
#    - No Azure Portal, sua app, aba "Authentication"
#    - Certifique-se que está registrada:
#      * http://localhost:5000/entra-callback (desenvolvimento)
#      * https://seu-dominio.com/entra-callback (produção)
#
# ============================================================================

# ============================================================================
# ESTRUTURA DE ARQUIVOS CRIADOS
# ============================================================================
#
# app/auth/entra_id.py
#   ├── EntraIDConfig        (gerencia variáveis de ambiente)
#   ├── EntraIDClient        (cliente MSAL para OIDC)
#   ├── create_csrf_token()  (proteção CSRF)
#   └── validate_email_in_database()  (valida email no BD)
#
# app/routes/entra_auth.py  (Blueprint com 3 rotas)
#   ├── /entra/login         (inicia autenticação)
#   ├── /entra/callback      (processa resposta do Entra ID)
#   └── /entra/logout        (faz logout)
#
# ============================================================================

# ============================================================================
# ROTEIRO RÁPIDO DE TESTE
# ============================================================================
#
# 1. Criar aplicação no Azure Portal (conforme instruções acima)
#
# 2. Preencher este .env com as credenciais
#
# 3. Instalar dependências:
#    pip install -r requirements.txt
#
# 4. Rodar a aplicação:
#    python app.py
#
# 5. No navegador:
#    http://localhost:5000/entra/login
#
# 6. Você será redirecionado para login do Entra ID
#
# 7. Após login bem-sucedido, será redirecionado para /entra/callback
#
# 8. Se o email estiver no BD (e ativo), será salvo na sessão
#
# 9. Acesse dados com: session.get('email'), session.get('name'), etc
#
# ============================================================================
