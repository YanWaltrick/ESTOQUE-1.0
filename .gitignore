# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.eggs/

# Ambiente / segredos
.env
.env.*
!.env.example
!.env.entra-id-example
venv/
.venv/

# mise: a config de projeto (mise.toml) é versionada; o override pessoal não
mise.local.toml
.mise.local.toml

# IDEs
.idea/
# Ignora configs pessoais do VS Code, mas versiona as compartilhadas do time
# (alinham o editor ao gate de lint do CI — ver docs/qualidade/ROADMAP.md).
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Logs
logs/*.log

# Testes / caches de ferramentas
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/
.mypy_cache/

# Banco local: o projeto usa MySQL; SQLite é legado e não deve ser versionado
*.db
*.sqlite
*.sqlite3

# Pasta instance do Flask: bancos locais nao versionados (pasta preservada via .gitkeep)
instance/*
!instance/.gitkeep

# Uploads de runtime (dados de usuário — recriados pela app na inicialização).
# Não versionar: incham o repo e expõem dados pessoais (LGPD).
static/uploads/

# Arquivos de sistema operacional
.DS_Store
Thumbs.db
desktop.ini
