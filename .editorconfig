# https://editorconfig.org — alinha os editores ao Ruff (docs/qualidade/ROADMAP.md).
# O fim de linha fica a cargo do git (core.autocrlf), por isso não é fixado aqui.
root = true

[*]
charset = utf-8
indent_style = space
trim_trailing_whitespace = true
insert_final_newline = true

[*.py]
indent_size = 4
max_line_length = 100

[*.{yml,yaml,json,toml}]
indent_size = 2

# Markdown usa dois espaços no fim da linha para forçar quebra — não os remova.
[*.md]
trim_trailing_whitespace = false
